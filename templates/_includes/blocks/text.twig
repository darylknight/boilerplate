{% import '_includes/macros' as macros %}

<div class="container mx-auto px-6 py-10 lg:py-20">
	<article class="prose">
		{{ block.text }}
	</article>

	{% set buttons = block.buttons.all() %}
	{% if buttons %}
		<div class="pt-10">
			{% for row in buttons %}
				{{ macros.button(row.button.url, row.button.label, 'btn mr-2', row.button.target) }}
			{% endfor %}
		</div>
	{% endif %}
</div>
